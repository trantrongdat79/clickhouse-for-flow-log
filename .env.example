# ClickHouse Configuration
CLICKHOUSE_VERSION=24.1
CLICKHOUSE_PASSWORD=secure_password_change_me
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Cluster Configuration
CLUSTER_NAME=netflow_cluster
# For initial testing: start with minimal cluster (1 shard, 1 replica)
# For full demo: 2 shards, 2 replicas each (4 nodes total)
SHARD_COUNT=1
REPLICA_COUNT=1

# ZooKeeper Configuration  
ZOOKEEPER_VERSION=3.8
ZK_TICK_TIME=2000

# Prometheus Configuration
PROMETHEUS_VERSION=v2.48.0
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_VERSION=10.2.3
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_change_me

# Data Generation
# Start small for testing: 2.5M records ~750MB
# Scale up for full demo: 250M records ~75GB
TOTAL_RECORDS=2500000
UNIQUE_SRC_IPS=10000
UNIQUE_DST_IPS=50000
TIME_RANGE_DAYS=60

# Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_LOCATION=./backups

# Development vs Production
ENVIRONMENT=development